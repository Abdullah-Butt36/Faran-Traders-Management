<?php
require_once 'config.php';
require_once 'includes/functions.php';

requireLogin();

if (!isset($_GET['id'])) {
    die("Invoice ID not specified.");
}

$sale_id = intval($_GET['id']);

// Get Sale Details
$stmt = $conn->prepare("SELECT s.*, c.name as customer_name, c.phone as customer_phone, c.city as customer_city 
                        FROM sales s 
                        JOIN customers c ON s.customer_id = c.id 
                        WHERE s.id = ?");
$stmt->bind_param("i", $sale_id);
$stmt->execute();
$sale = $stmt->get_result()->fetch_assoc();

if (!$sale) {
    die("Invoice not found.");
}

// Get Sale Items
$stmt = $conn->prepare("SELECT si.*, i.name as item_name, i.unit 
                        FROM sale_items si 
                        JOIN items i ON si.item_id = i.id 
                        WHERE si.sale_id = ?");
$stmt->bind_param("i", $sale_id);
$stmt->execute();
$result = $stmt->get_result();
$items = [];
while ($row = $result->fetch_assoc()) {
    $items[] = $row;
}
// Get Transaction History (Closing Balance at that time)
$stmt = $conn->prepare("SELECT balance FROM transactions WHERE invoice_no = ? AND transaction_type = 'Sale' LIMIT 1");
$stmt->bind_param("s", $sale['invoice_no']);
$stmt->execute();
$transResult = $stmt->get_result();

$closing_balance = 0;
$previous_balance = 0;

if ($transResult->num_rows > 0) {
    $trans = $transResult->fetch_assoc();
    $closing_balance = $trans['balance'];
    // Previous Balance = Closing Balance - (This Invoice Increase)
    // Increase = Total - Paid
    $invoice_increase = $sale['total_amount'] - $sale['payment_received'];
    $previous_balance = $closing_balance - $invoice_increase;
} else {
    // Fallback if transaction record missing (old data)
    // Just show current invoice impact
    $previous_balance = 0; 
    $closing_balance = $sale['balance']; 
}
