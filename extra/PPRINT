<?php
require_once 'config.php';
require_once 'includes/functions.php';

requireLogin();

if (!isset($_GET['id'])) {
    die("Invoice ID not specified.");
}

$purchase_id = intval($_GET['id']);

// Get Purchase Details
$stmt = $conn->prepare("SELECT p.*, s.name as supplier_name, s.phone as supplier_phone, s.city as supplier_city 
                        FROM purchases p 
                        JOIN suppliers s ON p.supplier_id = s.id 
                        WHERE p.id = ?");
$stmt->bind_param("i", $purchase_id);
$stmt->execute();
$purchase = $stmt->get_result()->fetch_assoc();

if (!$purchase) {
    die("Invoice not found.");
}

// Get Purchase Items
$stmt = $conn->prepare("SELECT pi.*, i.name as item_name, i.unit 
                        FROM purchase_items pi 
                        JOIN items i ON pi.item_id = i.id 
                        WHERE pi.purchase_id = ?");
$stmt->bind_param("i", $purchase_id);
$stmt->execute();
$result = $stmt->get_result();
$items = [];
while ($row = $result->fetch_assoc()) {
    $items[] = $row;
}
// Get Transaction History (Closing Balance at that time)
$stmt = $conn->prepare("SELECT balance FROM transactions WHERE invoice_no = ? AND transaction_type = 'Purchase' LIMIT 1");
$stmt->bind_param("s", $purchase['invoice_no']);
$stmt->execute();
$transResult = $stmt->get_result();

$closing_balance = 0;
$previous_balance = 0;
$invoice_total_cost = $purchase['total_amount'] + $purchase['transport_expense'] + $purchase['other_expense'];

if ($transResult->num_rows > 0) {
    $trans = $transResult->fetch_assoc();
    $closing_balance = $trans['balance'];
    // Previous Balance = Closing Balance - (This Invoice Increase)
    // Increase = Invoice Total - Paid
    $invoice_increase = $invoice_total_cost - $purchase['payment_made'];
    $previous_balance = $closing_balance - $invoice_increase;
} else {
    // Fallback if transaction record missing (old data)
    $previous_balance = 0; 
    $closing_balance = $purchase['balance']; 
}
